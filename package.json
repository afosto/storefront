{
  "name": "@afosto/storefront",
  "version": "4.0.3",
  "description": "Afosto storefront client",
  "keywords": [
    "afosto",
    "storefront",
    "storefront-client"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/afosto/storefront"
  },
  "author": "Afosto Saas BV",
  "license": "MIT",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/afosto/storefront/issues"
  },
  "homepage": "https://github.com/afosto/storefront",
  "scripts": {
    "cleanup": "rimraf dist",
    "dev": "rimraf dist && tsc --watch",
    "format": "prettier --write .",
    "prebuild": "rimraf dist",
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm cleanup && tsup **/*.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@afosto/graphql-client": "^3.0.0-alpha.7",
    "@types/js-cookie": "^3.0.6",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10"
  }
}
